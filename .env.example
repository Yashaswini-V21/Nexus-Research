# ── Nexus Research — Environment Variables ─────────────────────────────────

# Groq API key — https://console.groq.com/ (free tier available)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Tavily search API key — https://app.tavily.com/ (1000 free searches/month)
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# (Optional) Override Groq model. Default: llama-3.3-70b-versatile
# GROQ_MODEL=llama-3.3-70b-versatile

# (Optional) Per-IP rate limit for /api/research requests per minute
# RATE_LIMIT_RPM=15

# (Optional) Comma-separated allowed browser origins for CORS
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
